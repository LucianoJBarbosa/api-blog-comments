{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=api-blog-comments-dev.db"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:4200",
      "http://localhost:4200"
    ]
  },
  "Documentation": {
    "Enabled": true,
    "RoutePrefix": "docs",
    "DocumentName": "v1"
  },
  "Jwt": {
    "Issuer": "api-blog-comments-dev",
    "Audience": "api-blog-comments-clients-dev",
    "Key": "CHANGE_THIS_SECRET_KEY_IN_PRODUCTION_32_BYTES_MINIMUM"
  }
}

